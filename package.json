{
  "name": "etbaly-backend",
  "version": "1.0.0",
  "description": "Express.js Clean Architecture Backend",
  "main": "dist/src/server.js",
  "imports": {
    "#src/models/schemas": "./dist/src/models/schemas/index.js",
    "#src/jobs/mocks": "./dist/src/jobs/mocks/index.js",
    "#src/*": {
      "default": "./dist/src/*.js"
    }
  },
  "scripts": {
    "dev": "tsx watch --include src src/server.ts",
    "dev:api": "tsx watch --include src src/server.ts",
    "build": "tsc",
    "start": "node dist/src/server.js",
    "test": "jest --runInBand",
    "seed": "tsx src/seed/seed.ts --",
    "clear": "tsx src/seed/clear.ts --"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "moduleNameMapper": {
      "^#src/models/schemas$": "<rootDir>/src/models/schemas/index.ts",
      "^#src/jobs/mocks$": "<rootDir>/src/jobs/mocks/index.ts",
      "^#src/(.*)$": "<rootDir>/src/$1"
    },
    "testMatch": [
      "**/__tests__/**/*.test.ts"
    ]
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "bcrypt": "^6.0.0",
    "cloudinary": "^2.9.0",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "firebase-admin": "^13.7.0",
    "google-auth-library": "^10.5.0",
    "googleapis": "^171.4.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.2.1",
    "morgan": "^1.10.1",
    "multer": "^2.0.2",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/multer": "^2.0.0",
    "@types/node": "^25.3.0",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^7.0.11",
    "fast-check": "^4.6.0",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.6",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "overrides": {
    "minimatch": "^10.2.1"
  }
}
